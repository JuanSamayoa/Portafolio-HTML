---
/**
 * ABOUT SECTION - Sobre mí con enfoque QA/Dev
 * Layout moderno con stats y habilidades destacadas
 */

import Section from "../../shared/ui/Section.astro";
import Card from "../../shared/ui/Card.astro";
import Badge from "../../shared/ui/Badge.astro";

const stats = [
  { value: "3+", label: "Años de Experiencia" },
  { value: "20+", label: "Proyectos Completados" },
  { value: "90%", label: "Coverage en Tests" },
  { value: "100%", label: "Satisfacción Cliente" },
];

const mainSkills = [
  {
    category: "QA & Testing",
    items: ["Selenium", "Cypress", "Playwright", "Jest", "Test Strategy"],
  },
  {
    category: "Frontend",
    items: ["Angular", "TypeScript", "React", "Tailwind", "Astro"],
  },
  {
    category: "Backend",
    items: ["Node.js", "Express", "PostgreSQL", "REST APIs"],
  },
  {
    category: "DevOps",
    items: ["Git", "CI/CD", "Docker", "GitHub Actions"],
  },
];
---

<Section id="about" background="primary">
  <div class="space-y-20">
    <!-- Header -->
    <div class="text-center space-y-3">
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-success-400"
      >
        Sobre Mí
      </h2>
      <p class="text-base sm:text-lg text-foreground-secondary max-w-3xl mx-auto">
        Ingeniero de pruebas con pasión por el desarrollo de aplicaciones y la calidad
        del software
      </p>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
      {
        stats.map((stat, index) => (
          <div class="stat-card stat-card-stagger" data-index={index}>
            <div class="stat-card-inner">
              <div class="text-center space-y-1.5">
                <div class="stat-value text-3xl lg:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-br from-brand-400 to-success-400">
                  {stat.value}
                </div>
                <div class="text-xs sm:text-sm text-foreground-tertiary font-medium">{stat.label}</div>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Divider -->
    <div class="section-divider"></div>

    <!-- About content -->
    <div class="grid lg:grid-cols-2 gap-10 xl:gap-14 items-start">
      <!-- Columna izquierda - Descripción -->
      <Card variant="glass" padding="lg">
        <div class="space-y-6">
          <h3 class="text-xl lg:text-2xl font-bold text-foreground-primary trajectory-title">
            Mi Trayectoria
          </h3>

          <div class="space-y-4 text-foreground-secondary leading-relaxed text-sm sm:text-base">
            <p>
              Soy un <strong class="text-brand-400 font-semibold"
                >Ingeniero de Pruebas de Software (QA)</strong
              > con amplia experiencia en pruebas (funcionales, no funcionales, de humo,
              caja negra, caja blanca) y desarrollo de aplicaciones web. Mi enfoque combina la
              rigurosidad del QA con la creatividad del desarrollo.
            </p>

            <p>
              A lo largo de mi carrera, he trabajado en proyectos que van desde
              plataformas bancarias hasta sistemas de reportería en Power BI,
              siempre enfocándome en entregar
              <strong class="text-success-400 font-semibold">software de calidad </strong >
              y aprender mientras contribuyo al éxito del equipo.
            </p>

            <p>
              Me apasiona la automatización de procesos, el desarrollo de aplicaciones
              web, aplicaciones de escritorio y el aprendizaje continuo. Actualmente,
              busco oportunidades donde pueda combinar mi experiencia en QA con
              desarrollo Java, Python o Frontend para crear productos digitales robustos y
              escalables.
            </p>
          </div>

          <!-- Valores -->
          <div class="pt-5 border-t" style="border-color: var(--border-color);">
            <h4 class="text-sm font-semibold text-foreground-primary mb-3 uppercase tracking-wide">
              Valores que me definen
            </h4>
            <div class="flex flex-wrap gap-2">
              <Badge text="Calidad" variant="skill" />
              <Badge text="Innovación" variant="skill" />
              <Badge text="Responsabilidad" variant="skill" />
              <Badge text="Mejora continua" variant="skill" />
              <Badge text="Aprendizaje rápido" variant="skill" />
              <Badge text="Excelencia" variant="skill" />
              <Badge text="Autenticidad" variant="skill" />
            </div>
          </div>
        </div>
      </Card>

      <!-- Columna derecha - Skills -->
      <div class="space-y-5">
        {
          mainSkills.map((skillGroup) => (
            <Card variant="glass" padding="lg" hover class="skill-card">
              <h4 class="text-base lg:text-lg font-bold text-foreground-primary mb-4 flex items-center gap-2">
                <span class="w-1.5 h-1.5 bg-brand-400 rounded-full flex-shrink-0" />
                {skillGroup.category}
              </h4>
              <div class="flex flex-wrap gap-2">
                {skillGroup.items.map((skill) => (
                  <Badge text={skill} variant="tech" />
                ))}
              </div>
            </Card>
          ))
        }

        <!-- CTA adicional -->
        <Card variant="bordered" padding="md">
          <div class="text-center space-y-3">
            <p class="text-foreground-secondary text-sm">¿Interesado en colaborar?</p>
            <a
              href="#contact"
              class="inline-flex items-center gap-2 text-brand-400 hover:text-brand-300 font-semibold transition-colors"
            >
              Hablemos
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        </Card>
      </div>
    </div>
  </div>
</Section>

<style>
  /* Section divider */
  .section-divider {
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(26, 140, 255, 0.3), rgba(0, 204, 102, 0.3), transparent);
  }

  :global([data-theme="light"]) .section-divider {
    background: linear-gradient(to right, transparent, rgba(0, 102, 255, 0.2), rgba(0, 204, 102, 0.2), transparent);
  }

  /* Stat cards with gradient borders — theme-aware */
  .stat-card {
    position: relative;
    border-radius: 1rem;
    padding: 1.5rem;
    backdrop-filter: blur(12px);
    transition: all 0.3s ease;
    background: var(--card-bg);
  }

  .stat-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, var(--card-border-start), var(--card-border-end));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }

  .stat-card:hover::before {
    opacity: 1;
  }

  .stat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--card-hover-shadow);
  }

  .stat-card-inner {
    position: relative;
    z-index: 1;
  }

  :root, :root[data-theme="dark"] {
    --card-bg: rgba(17, 17, 19, 0.6);
    --card-border-start: rgba(26, 140, 255, 0.4);
    --card-border-end: rgba(0, 204, 102, 0.4);
    --card-hover-shadow: 0 12px 40px rgba(26, 140, 255, 0.15);
    --border-color: rgba(255, 255, 255, 0.1);
  }

  :root[data-theme="light"] {
    --card-bg: rgba(255, 255, 255, 0.75);
    --card-border-start: rgba(0, 102, 255, 0.3);
    --card-border-end: rgba(0, 204, 102, 0.3);
    --card-hover-shadow: 0 12px 40px rgba(0, 102, 255, 0.1);
    --border-color: rgba(0, 0, 0, 0.1);
  }

  /* Staggered animation for stat cards */
  .stat-card-stagger {
    opacity: 0;
    animation: stat-reveal 0.6s ease-out forwards;
  }

  .stat-card-stagger[data-index="0"] { animation-delay: 0.1s; }
  .stat-card-stagger[data-index="1"] { animation-delay: 0.2s; }
  .stat-card-stagger[data-index="2"] { animation-delay: 0.3s; }
  .stat-card-stagger[data-index="3"] { animation-delay: 0.4s; }

  @keyframes stat-reveal {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Trajectory title with left accent */
  .trajectory-title {
    position: relative;
    padding-left: 1rem;
  }

  .trajectory-title::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 70%;
    background: linear-gradient(to bottom, #1a8cff, #00cc66);
    border-radius: 2px;
  }

  /* Skill cards hover effect */
  .skill-card {
    transition: all 0.3s ease;
  }

  .skill-card:hover {
    border-color: var(--card-border-start);
  }
</style>
