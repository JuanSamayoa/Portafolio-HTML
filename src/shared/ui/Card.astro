---
/**
 * CARD COMPONENT - Contenedor reutilizable con glassmorphism
 * Diseño moderno con efecto de vidrio esmerilado
 */

interface Props {
  variant?: "glass" | "solid" | "bordered";
  padding?: "sm" | "md" | "lg";
  hover?: boolean;
  class?: string;
}

const {
  variant = "glass",
  padding = "md",
  hover = false,
  class: className = "",
} = Astro.props;

const variants = {
  glass: "bg-glass-heavy backdrop-blur-xl card-border",
  solid: "bg-background-elevated card-border-subtle",
  bordered: "bg-background-secondary border-2 border-brand-500/30",
};

const paddings = {
  sm: "p-4",
  md: "p-6",
  lg: "p-8",
};

const hoverClass = hover
  ? "card-hover"
  : "";

const classes = `${variants[variant]} ${paddings[padding]} ${hoverClass} rounded-2xl transition-all duration-300 ${className}`;
---

<div class={classes} data-variant={variant}>
  <slot />
</div>

<style>
  /* Theme-aware card borders using CSS variables */
  :root, :root[data-theme="dark"] {
    --card-border: rgba(255, 255, 255, 0.1);
    --card-border-subtle: rgba(255, 255, 255, 0.05);
    --card-border-hover: rgba(255, 255, 255, 0.2);
    --card-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    --card-shadow-hover: 0 20px 60px rgba(0, 102, 255, 0.15), 0 10px 40px rgba(0, 0, 0, 0.4);
  }

  :root[data-theme="light"] {
    --card-border: rgba(0, 0, 0, 0.1);
    --card-border-subtle: rgba(0, 0, 0, 0.05);
    --card-border-hover: rgba(0, 102, 255, 0.25);
    --card-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    --card-shadow-hover: 0 8px 40px rgba(0, 102, 255, 0.1), 0 4px 20px rgba(0, 0, 0, 0.12);
  }

  .card-border {
    border: 1px solid var(--card-border);
  }

  .card-border-subtle {
    border: 1px solid var(--card-border-subtle);
  }

  div {
    box-shadow: var(--card-shadow);
  }

  div:hover {
    box-shadow: var(--card-shadow-hover);
  }

  .card-hover {
    border-color: var(--card-border-hover) !important;
  }

  .card-hover:hover {
    transform: translateY(-8px) scale(1.01);
  }
</style>
